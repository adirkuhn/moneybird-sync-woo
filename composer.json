{
    "name": "vendor/moneybird-sync-for-woo",
    "description": "WooCommerce → Moneybird sync plugin using the Stripe Clearing Account model",
    "type": "wordpress-plugin",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.10",
        "phpstan/phpstan-strict-rules": "^1.5",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "wp-coding-standards/wpcs": "^3.1",
        "phpcompatibility/phpcompatibility-wp": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "MoneybirdSyncForWoo\\": "includes/",
            "MoneybirdSyncForWoo\\Models\\": "models/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MoneybirdSyncForWoo\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test":    "vendor/bin/phpunit",
        "phpstan": "vendor/bin/phpstan analyse --configuration=config/phpstan.neon",
        "phpcs":   "vendor/bin/phpcs --standard=config/phpcs.xml"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
